# Copy this file to .env and fill in the values
# IMPORTANT: Change all secret values before deploying!

# Shared secret between manager and portal (random string)
INTERNAL_TOKEN=replace-with-random-secret-string

# JWT signing secret (min 32 chars)
JWT_SECRET=replace-with-random-jwt-secret-at-least-32-chars

# Container limits
MAX_CONTAINERS=100
PORT_RANGE_START=20000
PORT_RANGE_END=25000

# DashScope API Key (shared by all user containers)
# https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# Docker image for openclaw user containers
# Build with: docker build -t openclaw-platform:latest ./openclaw-image
CONTAINER_IMAGE=openclaw-platform:latest
